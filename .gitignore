# ============================================
# Argus Trading Suite - .gitignore
# ============================================

# --- MQL5 Compiled Binaries ---
*.ex5
*.ex4

# --- Temporary & Build Files ---
*.log
*.tmp
*.bak

# --- MetaTrader Data Directories ---
MQL5/Logs/*
MQL5/Files/*
MQL5/Tester/*

# --- Python utility scripts (one-time use) ---
*.pyc
__pycache__/

# --- OS Generated Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
